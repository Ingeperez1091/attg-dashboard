{
  "name": "PL_NumeratorValidationProcessing",
  "properties": {
    "description": "Skeleton ADF pipeline for per-application validation processing runs.",
    "parameters": {
      "applicationId": {
        "type": "String"
      },
      "runId": {
        "type": "String"
      },
      "triggerSource": {
        "type": "String",
        "defaultValue": "ADF"
      },
      "actorUserId": {
        "type": "String"
      }
    },
    "activities": [
      {
        "name": "ExecutePipelineRun",
        "type": "SqlServerStoredProcedure",
        "typeProperties": {
          "storedProcedureName": "app.usp_ExecutePipelineRun",
          "storedProcedureParameters": {
            "runId": {
              "value": "@pipeline().parameters.runId",
              "type": "String"
            },
            "applicationId": {
              "value": "@pipeline().parameters.applicationId",
              "type": "String"
            },
            "triggerSource": {
              "value": "@pipeline().parameters.triggerSource",
              "type": "String"
            },
            "actorUserId": {
              "value": "@pipeline().parameters.actorUserId",
              "type": "String"
            }
          }
        },
        "policy": {
          "timeout": "00:30:00",
          "retry": 1,
          "retryIntervalInSeconds": 30
        }
      }
    ],
    "annotations": [
      "validation-processing",
      "foundation-skeleton"
    ]
  }
}
