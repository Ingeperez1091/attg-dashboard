<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- ASP.NET managed pipeline: raise query-string length to match IIS requestFiltering limit.
       Required because the Entra OAuth code parameter can exceed the 2048-byte default. -->
  <system.web>
    <httpRuntime maxQueryStringLength="16384" requestValidationMode="2.0" />
  </system.web>

  <system.webServer>
    <security>
      <requestFiltering>
        <!-- Entra callback can include large code/state values that exceed IIS defaults. -->
        <requestLimits maxQueryString="16384" maxUrl="32768" />
      </requestFiltering>
    </security>

    <iisnode
      nodeProcessCommandLine="node"
      devErrorsEnabled="true"
      loggingEnabled="true"
      logDirectory="iisnode"
      maxNamedPipeConnectionRetry="1000"
      namedPipeConnectionRetryDelay="250"
      nodeProcessCountPerApplication="1"
      flushResponse="false" />

    <!-- URL Rewrite Rules -->
    <rewrite>
      <rules>
        <rule name="Strip IISNode Named Pipe Prefix" stopProcessing="true">
          <match url="^/*(?:pipe/)?([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12})/(.*)$" />
          <action type="Rewrite" url="/{R:2}" />
        </rule>

        <rule name="Node App" stopProcessing="true">
          <match url=".*" />
          <action type="Rewrite" url="server.cjs" />
        </rule>
      </rules>
    </rewrite>

    <!-- Handlers -->
    <handlers>
      <add name="iisnode" path="server.cjs" verb="*" modules="iisnode" />
    </handlers>

  </system.webServer>

</configuration>
